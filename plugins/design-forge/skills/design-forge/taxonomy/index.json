{
  "version": "1.0.0",
  "description": "Design Forge taxonomy routing index. Claude reads this to map (platform, industry, style) to specific patterns.",

  "dimensions": {
    "platforms": ["website", "webapp", "mobile"],
    "industries": ["health", "saas", "fintech", "legal", "ecommerce", "creative", "services", "hospitality"],
    "styles": ["modern", "minimalistic", "glassmorphism", "futuristic", "brutalist", "organic"]
  },

  "defaults": {
    "platform": "webapp",
    "industry": "saas",
    "style": "modern"
  },

  "animation_intensities": {
    "minimal": {
      "duration_range": [0.15, 0.3],
      "stagger": 0.03,
      "easing": "ease-out",
      "scroll_effects": false,
      "description": "Near-instant transitions. Legal, fintech — no distraction."
    },
    "gentle": {
      "duration_range": [0.3, 0.6],
      "stagger": 0.06,
      "easing": "[0.16, 1, 0.3, 1]",
      "scroll_effects": true,
      "description": "Smooth but restrained. Health, education — builds trust."
    },
    "moderate": {
      "duration_range": [0.4, 0.8],
      "stagger": 0.08,
      "easing": "[0.25, 0.46, 0.45, 0.94]",
      "scroll_effects": true,
      "description": "Polished feel. SaaS, ecommerce — guides attention."
    },
    "expressive": {
      "duration_range": [0.5, 1.2],
      "stagger": 0.12,
      "easing": "[0.22, 1, 0.36, 1]",
      "scroll_effects": true,
      "description": "Bold and theatrical. Creative, portfolio — makes a statement."
    }
  },

  "scroll_choreography_presets": {
    "section-fade-sequence": "Sections fade in on scroll with stagger, counters animate on viewport entry",
    "apple-showcase": "Full-viewport pinned sections, scroll-scrubbed timelines, metric counters, sticky overlays",
    "parallax-layers": "Multi-layer parallax with depth separation, background moves slower than foreground",
    "horizontal-narrative": "Vertical scroll drives horizontal panel progression via GSAP containerAnimation"
  },

  "depth_strategies": {
    "css-layers": "Box shadows, subtle gradients, z-index layering — no JS libraries needed",
    "glassmorphism": "Backdrop blur + glass panels + translucent layers for depth",
    "parallax-3d": "CSS perspective + translateZ for real spatial depth without Three.js",
    "three-js-ambient": "Lightweight Three.js background (particles, gradient shader) for atmosphere"
  },

