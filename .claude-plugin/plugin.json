{
  "name": "composure",
  "description": "Code quality enforcement — decomposition hooks, architecture skills, impact-aware reviews, severity-tracked task queue. Works in Claude Code and Claude Cowork. Go with the grain.",
  "version": "1.4.0",
  "author": {
    "name": "Helder Rodrigues",
    "url": "https://github.com/hrconsultnj"
  },
  "homepage": "https://github.com/hrconsultnj/composure",
  "repository": "https://github.com/hrconsultnj/composure",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "architecture",
    "decomposition",
    "code-quality",
    "code-review",
    "knowledge-graph",
    "cowork",
    "multi-tenant",
    "saas",
    "tanstack-query",
    "supabase",
    "next-js",
    "react-native",
    "expo"
  ],
  "mcpServers": {
    "composure-graph": {
      "command": "node",
      "args": [
        "--experimental-sqlite",
        "${CLAUDE_PLUGIN_ROOT}/graph/dist/server.js"
      ]
    }
  },
  "capabilities": {
    "hooks": true,
    "skills": true,
    "commands": true,
    "agents": true,
    "mcp": true,
    "notifications": true,
    "dispatch_actions": true
  },
  "skills": "./skills/",
  "commands": "./commands/",
  "agents": "./agents/",
  "notifications": {
    "log_path": ".composure/notifications/pending.jsonl",
    "prune_after_hours": 48,
    "severity_levels": ["critical", "warning", "info"],
    "dispatch_commands": {
      "fix-violation": "/fix-violation",
      "quick-status": "/quick-status",
      "build-graph": "/build-graph"
    }
  }
}
